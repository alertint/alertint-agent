# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env — it is in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Bearer token that Alertmanager will include in every webhook request.
# Must be a long random string; generate one with: openssl rand -hex 32
ALERTINT_WEBHOOK_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Anthropic API key — AlertINT uses Claude for incident analysis.
# Create one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Bearer token that MCP clients (Claude Code, Cursor, Windsurf) use to authenticate.
# Must be a long random string; generate one with: openssl rand -hex 32
ALERTINT_MCP_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ── Optional: port overrides ──────────────────────────────────────────────────
# Change these if the default ports conflict with other services on your host.
# ALERTINT_WEBHOOK_PORT=9911
# ALERTINT_MCP_PORT=9912

# ── Optional: Slack notifications ─────────────────────────────────────────────

# Bot User OAuth Token for the Slack app (starts with xoxb-).
# Only needed when notify.slack.enabled is true in your config; the demo
# stack runs without it (findings go to stdout). The app needs the
# chat:write scope. See docs/CONFIGURATION.md (notify section) for setup.
# SLACK_BOT_TOKEN=xoxb-...
