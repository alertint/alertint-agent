# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env — it is in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Bearer token that Alertmanager will include in every webhook request.
# Must be a long random string; generate one with: openssl rand -hex 32
ALERTINT_WEBHOOK_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Anthropic API key — AlertINT uses Claude for incident analysis.
# Create one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Bearer token that MCP clients (Claude Code, Cursor, Windsurf) use to authenticate.
# Must be a long random string; generate one with: openssl rand -hex 32
ALERTINT_MCP_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Bearer token for the change webhook (deploy/config/flag events, and the
# planted deploy in `alertint drill`). Required with the example config, which
# ships changes.ingress enabled. Generate with: openssl rand -hex 32
ALERTINT_CHANGES_WEBHOOK_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ── Optional: local config override ───────────────────────────────────────────
# Run docker compose with your OWN config tweaks without editing the committed
# docker/agent.config.yaml (which stays the canonical demo config on GitHub).
# Make a local copy once, then point this at it:
#   cp docker/agent.config.yaml docker/agent.config.local.yaml
# Edit the copy freely (enable Slack, switch logs to Grafana Cloud, change the
# correlator window, etc.) — it is gitignored (docker/*.local.yaml), so your
# values persist across pulls and are never committed or overwritten.
# Path is relative to the docker/ directory. Unset → the demo config is used.
# ALERTINT_CONFIG_FILE=./agent.config.local.yaml

# ── Optional: port overrides ──────────────────────────────────────────────────
# Change these if the default ports conflict with other services on your host.
# ALERTINT_WEBHOOK_PORT=9911
# ALERTINT_MCP_PORT=9912

# ── Optional: Slack notifications ─────────────────────────────────────────────

# Bot User OAuth Token for the Slack app (starts with xoxb-).
# Only needed when notify.slack.enabled is true in your config; the demo
# stack runs without it (findings go to stdout). The app needs the
# chat:write scope. See docs/CONFIGURATION.md (notify section) for setup.
# SLACK_BOT_TOKEN=xoxb-...

# ── Optional: Grafana Cloud Logs (log-enrichment cloud variant) ───────────────
# Only needed to test enrichment against Grafana Cloud instead of the bundled
# local Loki (the demo's logs.loki points at the local Loki by default).
#
# Create ONE Access Policy token (Grafana Cloud Portal → Security → Access
# Policies → add token; realm = your stack) scoped to BOTH:
#   logs:write   — so `task logs:push:cloud` can push the synthetic lines
#   logs:read    — so the agent can query/enrich + serve loki_query_range
# NOTE: this is NOT the "Configured" password shown on the Grafana data-source
# page (that one is provisioned and unreadable). Find the URL + numeric user ID
# under your stack → Loki → "Send Logs". See docs/integrations/loki.md.
#
# Who reads what (so the apparent duplication makes sense):
#   GRAFANA_CLOUD_LOKI_TOKEN  — the SECRET. Used by BOTH the agent (named by
#                               logs.loki.auth.password_env in agent.config.yaml)
#                               and the push script. Always required for cloud.
#   GRAFANA_CLOUD_LOKI_URL    — used ONLY by `task logs:push:cloud`. The agent
#   GRAFANA_CLOUD_LOKI_USER     reads base_url/username from agent.config.yaml
#                               (they are not secrets and have no *_env form), so
#                               these two are needed only if you push via the
#                               script. Drop them if you push logs another way.
# GRAFANA_CLOUD_LOKI_URL=https://logs-prod-006.grafana.net
# GRAFANA_CLOUD_LOKI_USER=123456
# GRAFANA_CLOUD_LOKI_TOKEN=glc_...
