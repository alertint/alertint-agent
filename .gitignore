# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (never commit secrets); the committed example is allowed
.env*
!.env.example

# key material
*.key
*.pem

# Build artifacts
/bin/
/alertint

# Task runner cache
/.task/

# Python bytecode (docker/push-synthetic-logs.py is a convenience script)
__pycache__/
*.pyc

# Local config (copy of config.example.yaml)
/config.yaml

# Local Docker config overrides — copies of docker/agent.config.yaml that you
# tweak per-machine and select via ALERTINT_CONFIG_FILE in .env. The committed
# docker/agent.config.yaml stays the canonical demo config.
docker/*.local.yaml

# SQLite state (default path from config.example.yaml)
*.db
*.db-journal
*.db-shm
*.db-wal

# Editor/IDE
.idea/
.vscode/

# macOS
.DS_Store

.claude
CLAUDE.md
.agents/

# Internal agent/decision docs — kept local, NOT pushed to the public repo.
# Agents read them from the working tree (see .agents/domain.md); none render
# on alertint.com/docs. The public, user-facing counterpart is docs/integrations/*.
/CONTEXT.md
/docs/adr/
/specs/
/plans/
.scratch/
/planning/

.compound-engineering/
/.ce/
/STRATEGY.md
/CONCEPTS.md
/docs/brainstorms/
/docs/plans/
/docs/ideation/
/docs/solutions/
/docs/pulse-reports/
/docs/residual-review-findings/
/docs/dogfood-reports/

# Triage eval harness failure artifacts (CI uploads them as artifacts)
/internal/triage/testdata/.last-failures/
